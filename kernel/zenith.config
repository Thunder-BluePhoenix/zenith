# Zenith Custom Linux Kernel Configuration
# ==========================================
# Build target: x86_64 Firecracker MicroVM
# Goal:         sub-50ms boot time, < 4MB kernel image
# Based on:     Linux 6.6 LTS
#
# To build:
#   make ARCH=x86_64 CROSS_COMPILE=x86_64-linux-gnu- zenith_defconfig
#   make ARCH=x86_64 CROSS_COMPILE=x86_64-linux-gnu- -j$(nproc)
#   # Output: arch/x86/boot/compressed/vmlinux.bin (strip + compress)
#
# Verify boot time:
#   time zenith lab create --os zenith    # should print <50ms
#
# This config is tuned for CI/CD workloads, NOT general-purpose Linux.
# Missing features are intentional — add only what CI actually needs.

# ─── Architecture ─────────────────────────────────────────────────────────────
CONFIG_X86_64=y
CONFIG_64BIT=y
CONFIG_SMP=y                    # multi-core support for matrix jobs
CONFIG_NR_CPUS=16

# ─── Virtualization / KVM guest ───────────────────────────────────────────────
CONFIG_HYPERVISOR_GUEST=y
CONFIG_PARAVIRT=y
CONFIG_KVM_GUEST=y              # paravirt clock, steal time accounting
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BALLOON=n         # not needed in CI
CONFIG_VIRTIO_BLK=y             # root disk (ext4 rootfs image)
CONFIG_VIRTIO_NET=y             # network for curl/git in steps
CONFIG_VIRTIO_CONSOLE=y         # /dev/hvc0 and /dev/hvc1 for zenith-init
CONFIG_VSOCKETS=y               # vsock for future daemon communication
CONFIG_VIRTIO_VSOCKETS=y

# ─── Filesystem ───────────────────────────────────────────────────────────────
CONFIG_EXT4_FS=y                # root filesystem
CONFIG_OVERLAY_FS=y             # per-run writable overlay
CONFIG_TMPFS=y                  # /tmp in RAM
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y               # /dev auto-population

# ─── Network ──────────────────────────────────────────────────────────────────
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=n                   # not needed for CI, saves ~200KB
CONFIG_PACKET=y                 # raw sockets for DHCP
CONFIG_UNIX=y                   # local sockets for zenith-init

# ─── Block / storage ──────────────────────────────────────────────────────────
CONFIG_BLOCK=y
CONFIG_BLK_DEV=y
CONFIG_BLK_DEV_LOOP=n           # not needed
CONFIG_SCSI=n                   # not needed — virtio-blk only

# ─── Process / memory ─────────────────────────────────────────────────────────
CONFIG_MEMCG=y                  # memory cgroups for resource limits (Phase 14)
CONFIG_CGROUP_SCHED=y
CONFIG_FAIR_GROUP_SCHED=y
CONFIG_CGROUPS=y
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_SECCOMP=y                # syscall filtering for security

# ─── Serial / console ─────────────────────────────────────────────────────────
CONFIG_SERIAL_8250=y            # ttyS0 — Firecracker log output
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_HVC_DRIVER=y             # hvc0, hvc1 — virtio-console channels
CONFIG_HVC_IRQ=y

# ─── Power management ─────────────────────────────────────────────────────────
CONFIG_ACPI=y
CONFIG_ACPI_BUTTON=y            # power button for clean VM shutdown

# ─── Explicitly DISABLED for size/speed ───────────────────────────────────────
CONFIG_USB_SUPPORT=n
CONFIG_SOUND=n
CONFIG_SND=n
CONFIG_DRM=n
CONFIG_FB=n
CONFIG_WIRELESS=n
CONFIG_WLAN=n
CONFIG_BLUETOOTH=n
CONFIG_PCMCIA=n
CONFIG_PCCARD=n
CONFIG_MTD=n
CONFIG_INFINIBAND=n
CONFIG_NFS_FS=n
CONFIG_CIFS=n
CONFIG_SMB_SERVER=n
CONFIG_FUSE_FS=n
CONFIG_BTRFS_FS=n
CONFIG_XFS_FS=n
CONFIG_JFS_FS=n
CONFIG_REISERFS_FS=n
CONFIG_NTFS_FS=n
CONFIG_HID=n
CONFIG_HID_GENERIC=n
CONFIG_INPUT=n
CONFIG_MOUSE_PS2=n
CONFIG_KEYBOARD_ATKBD=n
CONFIG_AGP=n
CONFIG_PCI_LEGACY=n             # Firecracker uses virtio, not legacy PCI
CONFIG_X86_PLATFORM_DEVICES=n
CONFIG_X86_THERMAL_VECTOR=n

# ─── Debug / tracing (production build — all off) ─────────────────────────────
CONFIG_DEBUG_KERNEL=n
CONFIG_FTRACE=n
CONFIG_KPROBES=n
CONFIG_DYNAMIC_DEBUG=n
CONFIG_DEBUG_FS=n
CONFIG_PERF_EVENTS=n
CONFIG_PROFILING=n
