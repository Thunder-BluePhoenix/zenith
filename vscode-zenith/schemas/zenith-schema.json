{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Zenith Workflow Configuration",
  "description": "Schema for .zenith.yml workflow configuration files (v2)",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version — use '2' to enable all Phase 6–13 features",
      "enum": ["1", "2"],
      "default": "1"
    },
    "name": {
      "type": "string",
      "description": "Human-readable workflow name"
    },
    "on": {
      "type": "object",
      "description": "Trigger conditions (informational; local runner ignores these)"
    },
    "env": {
      "type": "object",
      "description": "Global toolchain declarations (node, python, go, rust)",
      "properties": {
        "node":   { "type": "string", "description": "Node.js version, e.g. '20'" },
        "python": { "type": "string", "description": "Python version, e.g. '3.12.3'" },
        "go":     { "type": "string", "description": "Go version, e.g. '1.22.0'" },
        "rust":   { "type": "string", "description": "Rust toolchain, e.g. 'stable'" }
      },
      "additionalProperties": { "type": "string" }
    },
    "cache": {
      "type": "object",
      "description": "Top-level cache settings (v2 schema, Phase 14)",
      "properties": {
        "ttl_days": {
          "type": "integer",
          "description": "Maximum cache entry age in days before pruning (default: 7)",
          "default": 7,
          "minimum": 1
        },
        "remote": {
          "type": "string",
          "description": "URL of the remote binary cache server",
          "examples": ["https://cache.zenith.run"]
        },
        "push": {
          "type": "boolean",
          "description": "Automatically push build outputs to the remote cache",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "jobs": {
      "type": "object",
      "description": "Map of job name to job definition",
      "additionalProperties": {
        "$ref": "#/definitions/job"
      }
    },
    "steps": {
      "type": "array",
      "description": "Flat list of steps (legacy single-job format)",
      "items": { "$ref": "#/definitions/step" }
    }
  },
  "definitions": {
    "job": {
      "type": "object",
      "required": ["steps"],
      "properties": {
        "runs-on": {
          "type": "string",
          "description": "OS image for the job (e.g. alpine, ubuntu, centos)",
          "default": "alpine"
        },
        "backend": {
          "type": "string",
          "description": "Execution backend: container, firecracker, wasm, wine, or plugin name",
          "enum": ["container", "firecracker", "wasm", "wine"],
          "default": "container"
        },
        "arch": {
          "type": "string",
          "description": "Target CPU architecture (x86_64, aarch64)",
          "enum": ["x86_64", "aarch64"]
        },
        "env": {
          "type": "object",
          "description": "Job-level environment variables",
          "additionalProperties": { "type": "string" }
        },
        "toolchain": {
          "type": "object",
          "description": "Per-job toolchain overrides (takes priority over top-level env block)",
          "properties": {
            "node":   { "type": "string" },
            "python": { "type": "string" },
            "go":     { "type": "string" },
            "rust":   { "type": "string" }
          }
        },
        "working_directory": {
          "type": "string",
          "description": "Working directory for all steps in this job"
        },
        "cache": {
          "type": "boolean",
          "description": "Enable or disable step-level caching for this entire job",
          "default": true
        },
        "strategy": {
          "type": "object",
          "description": "Matrix strategy for parallel multi-OS/multi-version runs",
          "required": ["matrix"],
          "properties": {
            "matrix": {
              "type": "object",
              "description": "Map of variable name to list of values",
              "additionalProperties": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "steps": {
          "type": "array",
          "description": "Ordered list of steps",
          "items": { "$ref": "#/definitions/step" }
        }
      }
    },
    "step": {
      "type": "object",
      "required": ["run"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Step display name (also used as a dependency target in depends_on)"
        },
        "run": {
          "type": "string",
          "description": "Shell command(s) to execute"
        },
        "env": {
          "type": "object",
          "description": "Environment variables for this step",
          "additionalProperties": { "type": "string" }
        },
        "working_directory": {
          "type": "string",
          "description": "Override working directory for this step"
        },
        "allow_failure": {
          "type": "boolean",
          "description": "If true, this step can fail without aborting the job",
          "default": false
        },
        "cache": {
          "type": "boolean",
          "description": "Enable or disable caching for this specific step",
          "default": true
        },
        "cache_key": {
          "type": "string",
          "description": "Manual cache key override — disables OS/arch in the hash for cross-platform artifact sharing"
        },
        "watch": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Glob patterns for files whose content changes invalidate the cache",
          "examples": [["src/**/*.rs", "Cargo.toml"]]
        },
        "outputs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Paths to files/directories produced by this step — archived on cache miss, restored on hit",
          "examples": [["target/release/myapp", "dist/"]]
        },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Step names that must complete before this step starts (enables parallel execution)",
          "examples": [["Build", "Install deps"]]
        }
      }
    }
  }
}
