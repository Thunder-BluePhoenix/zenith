# Generated by Cargo
target/

# Cargo.lock is committed for binaries, not libraries
# (keep it — this is a binary crate)

# Rust backup files
**/*.rs.bk

# Windows debug symbols
*.pdb

# Claude Code local settings (project-level agent config)
.claude/

# IDEs and editors
.vscode/
.idea/
.DS_Store
*.swp
*.suo
*.user

# Zenith local runtime data (~/.zenith is outside repo, but guard local overrides)
.zenith/
.zenith.yml.bak

# Secrets / local config
.env
.env.*
!.env.example

# Temporary debug / build log files
*.log
build_out.txt
build_err*.txt
matrix_out.txt
firecracker_out.txt
phase_5_out.txt
wasm_out*.txt
err*.txt
test_output.txt

# OS cruft
Thumbs.db
Desktop.ini
